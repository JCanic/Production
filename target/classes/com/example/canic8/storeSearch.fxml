<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="413.0" prefWidth="632.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.canic8.SearchStoresController">
    <children>
        <TextField fx:id="name" layoutX="398.0" layoutY="66.0" />
        <Label layoutX="290.0" layoutY="71.0" text="Enter store name: " />
        <Button layoutX="279.0" layoutY="126.0" mnemonicParsing="false" onAction="#search" text="Search" />
        <TableView fx:id="storeTable" layoutX="14.0" layoutY="180.0" prefHeight="200.0" prefWidth="607.0">
            <columns>
                <TableColumn fx:id="storeNameColumn" prefWidth="113.0" text="Name" />
                <TableColumn fx:id="storeWebAddressColumn" prefWidth="95.0" text="Web address" />
                <TableColumn fx:id="storeItemColumn" prefWidth="369.0" text="Items" />
            </columns>
        </TableView>
        <Text layoutX="282.0" layoutY="54.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Store search">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Text>
        <fx:include source="menuBar.fxml" />
    </children>
</AnchorPane>
