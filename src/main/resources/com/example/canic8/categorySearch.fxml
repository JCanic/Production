<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="473.0" prefWidth="631.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.canic8.SearchCategoriesController">
    <children>
        <TextField fx:id="name" layoutX="398.0" layoutY="66.0" />
        <Label layoutX="273.0" layoutY="71.0" text="Enter Category name: " />
        <Button layoutX="245.0" layoutY="147.0" mnemonicParsing="false" onAction="#search" text="Search" />
        <TableView fx:id="categoryTable" layoutX="14.0" layoutY="180.0" prefHeight="200.0" prefWidth="584.0">
            <columns>
                <TableColumn fx:id="categoryNameColumn" prefWidth="150.0" text="Name" />
                <TableColumn fx:id="categoryDescriptionColumn" prefWidth="433.0" text="Description" />
            </columns>
        </TableView>
        <Text layoutX="282.0" layoutY="54.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Category search">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Text>
        <fx:include source="menuBar.fxml" />
    </children>
</AnchorPane>
